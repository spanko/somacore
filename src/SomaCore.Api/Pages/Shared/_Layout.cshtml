<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] · SomaCore</title>
    <style>
        :root {
            color-scheme: light dark;
            --bg: Canvas;
            --fg: CanvasText;
            --muted: GrayText;
            --accent: #0b6cf2;
            --card-bg: color-mix(in srgb, CanvasText 5%, Canvas);
            --card-border: color-mix(in srgb, CanvasText 12%, Canvas);
        }
        body {
            margin: 0;
            font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            background: var(--bg);
            color: var(--fg);
            line-height: 1.45;
        }
        main {
            max-width: 640px;
            margin: 0 auto;
            padding: 1.5rem 1rem 4rem;
        }
        h1 {
            font-size: 1.6rem;
            margin: 0 0 0.25rem;
        }
        .subtitle {
            color: var(--muted);
            margin: 0 0 1.5rem;
        }
        .card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            padding: 1rem 1.1rem;
            margin: 0 0 1rem;
        }
        .card h2 {
            font-size: 1.05rem;
            margin: 0 0 0.5rem;
        }
        .btn {
            display: inline-block;
            padding: 0.5rem 0.9rem;
            border-radius: 8px;
            background: var(--accent);
            color: white;
            text-decoration: none;
            font-weight: 500;
        }
        .btn:hover { filter: brightness(1.1); }
        .btn-secondary {
            background: transparent;
            color: var(--accent);
            border: 1px solid var(--accent);
        }
        .banner {
            padding: 0.6rem 0.9rem;
            border-radius: 8px;
            background: color-mix(in srgb, var(--accent) 10%, Canvas);
            border: 1px solid color-mix(in srgb, var(--accent) 30%, Canvas);
            margin: 0 0 1rem;
        }
        .banner-warning {
            padding: 0.75rem 0.95rem;
            border-radius: 8px;
            background: #f59e0b18;
            border: 1px solid #f59e0b66;
            color: #92400e;
            margin: 0 0 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-wrap: wrap;
        }
        @@media (prefers-color-scheme: dark) {
            .banner-warning { color: #fcd34d; }
        }
        .banner-warning .banner-text { flex: 1; min-width: 16ch; }
        .banner-warning .btn { background: #f59e0b; color: #1c1917; }
        .disconnect-form {
            margin-top: 0.5rem;
        }
        .btn-link-danger {
            background: none;
            border: none;
            padding: 0;
            color: var(--muted);
            font-size: 0.85rem;
            text-decoration: underline;
            cursor: pointer;
            font-family: inherit;
        }
        .btn-link-danger:hover { color: #b91c1c; }
        .recovery {
            display: flex;
            align-items: center;
            gap: 1.25rem;
        }
        .recovery-score {
            font-size: 3.25rem;
            font-weight: 700;
            line-height: 1;
        }
        .recovery-detail { flex: 1; }
        .metrics {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 0.15rem 0.8rem;
            margin: 0.5rem 0 0;
        }
        .metrics dt {
            color: var(--muted);
            font-size: 0.85rem;
            margin: 0;
        }
        .metrics dd { margin: 0; font-variant-numeric: tabular-nums; }
        .badge {
            display: inline-block;
            padding: 0.15rem 0.5rem;
            border-radius: 999px;
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.04em;
        }
        .badge-scored     { background: #16a34a22; color: #16a34a; }
        .badge-pending    { background: #f59e0b22; color: #c1812a; }
        .badge-unscorable { background: #6b728033; color: var(--muted); }
        .status-dot {
            display: inline-block;
            width: 0.6rem;
            height: 0.6rem;
            border-radius: 50%;
            margin-right: 0.4rem;
            vertical-align: middle;
        }
        .status-dot-ok { background: #16a34a; box-shadow: 0 0 0 3px #16a34a22; }
        .hint {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-wrap: wrap;
            margin-top: 1rem;
        }
        .hint-text {
            color: var(--muted);
            font-size: 0.85rem;
            flex: 1;
        }
        details { margin-top: 1.5rem; }
        details summary {
            cursor: pointer;
            color: var(--muted);
            font-size: 0.92rem;
        }
        dl { margin: 0.75rem 0 0; }
        dt { color: var(--muted); font-size: 0.85rem; margin-top: 0.5rem; }
        dd { margin: 0.1rem 0 0; }
        code { font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 0.9em; }
        .signout {
            margin-top: 2rem;
            font-size: 0.9rem;
            color: var(--muted);
        }
        .signout a { color: inherit; }
        .admin-table-wrap { overflow-x: auto; margin-top: 1rem; }
        .admin-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.92rem;
        }
        .admin-table th,
        .admin-table td {
            text-align: left;
            padding: 0.6rem 0.7rem;
            border-bottom: 1px solid var(--card-border);
            vertical-align: top;
        }
        .admin-table th {
            font-weight: 600;
            color: var(--muted);
            font-size: 0.78rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            background: var(--card-bg);
        }
        .admin-table td .subtitle { font-size: 0.78rem; margin: 0.15rem 0 0; }

        /* ------------------------------------------------------------------
           Coach surfaces (/me/coach) — the training-log design language.
           Evidence chips carry a monospace data voice; the coach speaks
           flush-left behind a teal rule, like an annotation in the margin
           of a training log. Teal is the coach's color — distinct from the
           product-blue accent and the score badges.
           ------------------------------------------------------------------ */
        :root {
            --coach: #0d9488;
            --coach-soft: color-mix(in srgb, #0d9488 9%, Canvas);
            --coach-border: color-mix(in srgb, #0d9488 35%, Canvas);
            --mono: ui-monospace, "SF Mono", "Cascadia Mono", Menlo, monospace;
        }
        .chip {
            display: flex;
            align-items: baseline;
            gap: 0.6rem;
            padding: 0.55rem 0.75rem;
            border: 1px solid var(--card-border);
            border-radius: 8px;
            margin: 0 0 0.5rem;
            background: var(--card-bg);
            font-family: var(--mono);
            font-size: 0.83rem;
        }
        .chip-tag {
            font-weight: 700;
            font-size: 0.7rem;
            letter-spacing: 0.08em;
            flex-shrink: 0;
        }
        .chip-tag-meal { color: #c1812a; }
        .chip-tag-work { color: #16a34a; }
        .chip-tag-note { color: var(--muted); }
        .chip-tag-doc  { color: var(--accent); }
        .chip-body { flex: 1; min-width: 0; overflow-wrap: anywhere; }
        .chip-when { color: var(--muted); font-size: 0.72rem; flex-shrink: 0; }
        .chip-actions { display: flex; gap: 0.6rem; flex-shrink: 0; }
        .chip-actions .btn-link,
        .btn-link {
            background: none; border: none; padding: 0; cursor: pointer;
            font-family: inherit; font-size: 0.78rem;
            color: var(--coach); text-decoration: underline;
        }
        .btn-link:hover { filter: brightness(1.2); }
        .chip--pinned {
            border-color: var(--coach-border);
            background: var(--coach-soft);
            position: sticky; top: 0.5rem; z-index: 2;
        }
        /* Structured input: radio-driven tabs, no JS. */
        .log-tabs { display: flex; gap: 0.4rem; flex-wrap: wrap; margin: 0 0 0.9rem; }
        .log-tabs input[type="radio"] { position: absolute; opacity: 0; pointer-events: none; }
        .log-tabs label {
            padding: 0.35rem 0.8rem;
            border: 1px solid var(--card-border);
            border-radius: 999px;
            font-size: 0.83rem;
            cursor: pointer;
            font-family: var(--mono);
            letter-spacing: 0.04em;
        }
        .log-tabs input:checked + label {
            border-color: var(--coach);
            background: var(--coach-soft);
            color: var(--coach);
            font-weight: 700;
        }
        .log-tabs input:focus-visible + label { outline: 2px solid var(--coach); outline-offset: 2px; }
        .log-panel { display: none; }
        #tab-meal:checked ~ .log-panels #panel-meal,
        #tab-work:checked ~ .log-panels #panel-work,
        #tab-note:checked ~ .log-panels #panel-note,
        #tab-doc:checked  ~ .log-panels #panel-doc { display: block; }
        .field-row { display: flex; gap: 0.6rem; flex-wrap: wrap; margin: 0 0 0.6rem; }
        .field { display: flex; flex-direction: column; gap: 0.2rem; flex: 1; min-width: 8.5rem; }
        .field > span { font-size: 0.75rem; color: var(--muted); letter-spacing: 0.03em; }
        .field input, .field select, .quicklog-form input[type="text"], .thread-input input[type="text"] {
            padding: 0.5rem 0.6rem;
            border: 1px solid var(--card-border);
            border-radius: 8px;
            background: var(--bg);
            color: var(--fg);
            font-family: inherit;
            font-size: 0.95rem;
        }
        .field input:focus-visible, .thread-input input:focus-visible {
            outline: 2px solid var(--coach); outline-offset: 1px;
        }
        .btn-coach {
            display: inline-block;
            padding: 0.5rem 1rem;
            border: none;
            border-radius: 8px;
            background: var(--coach);
            color: white;
            font-weight: 600;
            font-family: inherit;
            font-size: 0.95rem;
            cursor: pointer;
        }
        .btn-coach:hover { filter: brightness(1.1); }
        /* The conversation log. Coach = flush-left behind a teal rule (a
           margin annotation); user = quiet right-aligned card. No bubbles. */
        .thread { margin: 1rem 0; }
        .msg { margin: 0 0 1rem; max-width: 92%; }
        .msg-user {
            margin-left: auto;
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 10px;
            padding: 0.6rem 0.85rem;
            width: fit-content;
        }
        .msg-coach {
            border-left: 3px solid var(--coach);
            padding: 0.15rem 0 0.15rem 0.85rem;
        }
        .msg-coach.msg-refusal { border-left-color: #f59e0b; }
        .msg-meta {
            font-family: var(--mono);
            font-size: 0.68rem;
            color: var(--muted);
            letter-spacing: 0.06em;
            margin: 0 0 0.25rem;
        }
        .msg p { margin: 0; }
        .thread-input { display: flex; gap: 0.5rem; margin-top: 1rem; }
        .thread-input input { flex: 1; }
        .turns-left {
            font-family: var(--mono);
            font-size: 0.72rem;
            color: var(--muted);
            margin-top: 0.4rem;
        }
        .quicklog-form { display: flex; gap: 0.5rem; }
        .quicklog-form input[type="text"] { flex: 1; }
        .quicklog-confirm {
            border-left: 3px solid var(--coach);
            padding: 0.3rem 0 0.3rem 0.85rem;
            margin: 0.75rem 0;
            animation: readback 0.25s ease-out;
        }
        .quicklog-confirm-actions { display: flex; gap: 0.6rem; margin-top: 0.6rem; align-items: center; }
        .quicklog-items { list-style: none; padding: 0; margin: 0.5rem 0 0; }
        .quicklog-items li {
            display: flex; align-items: baseline; gap: 0.6rem;
            padding: 0.4rem 0; border-bottom: 1px solid var(--card-border);
            font-size: 0.9rem;
        }
        .quicklog-items li form { margin-left: auto; }
        .banner-success {
            padding: 0.6rem 0.9rem; border-radius: 8px;
            background: color-mix(in srgb, var(--coach) 10%, Canvas);
            border: 1px solid var(--coach-border);
            margin: 0 0 1rem;
        }
        .inline-form { display: inline; }
        @@keyframes readback {
            from { opacity: 0; transform: translateY(4px); }
            to   { opacity: 1; transform: none; }
        }
        @@media (prefers-reduced-motion: reduce) {
            .quicklog-confirm { animation: none; }
        }
    </style>
</head>
<body>
    <main>
        @RenderBody()
    </main>
</body>
</html>
