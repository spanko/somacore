<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] · SomaCore</title>
    <style>
        :root {
            color-scheme: light dark;
            --bg: Canvas;
            --fg: CanvasText;
            --muted: GrayText;
            --accent: #0b6cf2;
            --card-bg: color-mix(in srgb, CanvasText 5%, Canvas);
            --card-border: color-mix(in srgb, CanvasText 12%, Canvas);
        }
        body {
            margin: 0;
            font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            background: var(--bg);
            color: var(--fg);
            line-height: 1.45;
        }
        main {
            max-width: 640px;
            margin: 0 auto;
            padding: 1.5rem 1rem 4rem;
        }
        h1 {
            font-size: 1.6rem;
            margin: 0 0 0.25rem;
        }
        .subtitle {
            color: var(--muted);
            margin: 0 0 1.5rem;
        }
        .card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            padding: 1rem 1.1rem;
            margin: 0 0 1rem;
        }
        .card h2 {
            font-size: 1.05rem;
            margin: 0 0 0.5rem;
        }
        .btn {
            display: inline-block;
            padding: 0.5rem 0.9rem;
            border-radius: 8px;
            background: var(--accent);
            color: white;
            text-decoration: none;
            font-weight: 500;
        }
        .btn:hover { filter: brightness(1.1); }
        .btn-secondary {
            background: transparent;
            color: var(--accent);
            border: 1px solid var(--accent);
        }
        .banner {
            padding: 0.6rem 0.9rem;
            border-radius: 8px;
            background: color-mix(in srgb, var(--accent) 10%, Canvas);
            border: 1px solid color-mix(in srgb, var(--accent) 30%, Canvas);
            margin: 0 0 1rem;
        }
        .recovery {
            display: flex;
            align-items: center;
            gap: 1.25rem;
        }
        .recovery-score {
            font-size: 3.25rem;
            font-weight: 700;
            line-height: 1;
        }
        .recovery-detail { flex: 1; }
        .metrics {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 0.15rem 0.8rem;
            margin: 0.5rem 0 0;
        }
        .metrics dt {
            color: var(--muted);
            font-size: 0.85rem;
            margin: 0;
        }
        .metrics dd { margin: 0; font-variant-numeric: tabular-nums; }
        .badge {
            display: inline-block;
            padding: 0.15rem 0.5rem;
            border-radius: 999px;
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.04em;
        }
        .badge-scored     { background: #16a34a22; color: #16a34a; }
        .badge-pending    { background: #f59e0b22; color: #c1812a; }
        .badge-unscorable { background: #6b728033; color: var(--muted); }
        .status-dot {
            display: inline-block;
            width: 0.6rem;
            height: 0.6rem;
            border-radius: 50%;
            margin-right: 0.4rem;
            vertical-align: middle;
        }
        .status-dot-ok { background: #16a34a; box-shadow: 0 0 0 3px #16a34a22; }
        .hint {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-wrap: wrap;
            margin-top: 1rem;
        }
        .hint-text {
            color: var(--muted);
            font-size: 0.85rem;
            flex: 1;
        }
        details { margin-top: 1.5rem; }
        details summary {
            cursor: pointer;
            color: var(--muted);
            font-size: 0.92rem;
        }
        dl { margin: 0.75rem 0 0; }
        dt { color: var(--muted); font-size: 0.85rem; margin-top: 0.5rem; }
        dd { margin: 0.1rem 0 0; }
        code { font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 0.9em; }
        .signout {
            margin-top: 2rem;
            font-size: 0.9rem;
            color: var(--muted);
        }
        .signout a { color: inherit; }
        .admin-table-wrap { overflow-x: auto; margin-top: 1rem; }
        .admin-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.92rem;
        }
        .admin-table th,
        .admin-table td {
            text-align: left;
            padding: 0.6rem 0.7rem;
            border-bottom: 1px solid var(--card-border);
            vertical-align: top;
        }
        .admin-table th {
            font-weight: 600;
            color: var(--muted);
            font-size: 0.78rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            background: var(--card-bg);
        }
        .admin-table td .subtitle { font-size: 0.78rem; margin: 0.15rem 0 0; }
    </style>
</head>
<body>
    <main>
        @RenderBody()
    </main>
</body>
</html>
