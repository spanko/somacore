@page "/me"
@model SomaCore.Api.Pages.MeModel
@using SomaCore.Api.Time
@using SomaCore.Domain.Agent
@using SomaCore.Domain.WhoopRecoveries
@{
    ViewData["Title"] = "/me";
}

<h1>Welcome, @Model.DisplayName</h1>
<p class="subtitle">Signed in as @Model.Email</p>

@if (!string.IsNullOrEmpty(Model.WhoopBanner))
{
    <p class="banner">@Model.WhoopBanner</p>
}

@if (Model.WhoopNeedsReconnect)
{
    <div class="banner-warning" role="alert">
        <span class="banner-text">Your WHOOP connection needs to be refreshed.</span>
        <a class="btn" href="/auth/whoop/start">Reconnect WHOOP</a>
    </div>
}

@if (Model.ForcedOnOpenPull)
{
    <p class="banner">Forced on-open pull triggered (<code>?force=true</code>). Check the latest recovery's <em>Provenance</em> for <code>ingested_via = on_open_pull</code>.</p>
}

<section class="card">
    <h2>WHOOP</h2>
    @if (Model.WhoopConnected)
    {
        <p>
            <span class="status-dot status-dot-ok" aria-hidden="true"></span>
            <strong>Connected.</strong> SomaCore is receiving data from your WHOOP account.
        </p>
        <dl class="metrics">
            @if (Model.WhoopUserId.HasValue)
            {
                <dt>WHOOP user</dt>
                <dd><code>@Model.WhoopUserId</code></dd>
            }
            @if (!string.IsNullOrEmpty(Model.WhoopEmail))
            {
                <dt>WHOOP email</dt>
                <dd>@Model.WhoopEmail</dd>
            }
            <dt>Connected since</dt>
            <dd>@MountainTime.Format(Model.WhoopConnectedAt)</dd>
        </dl>
        <p class="hint">
            <a class="btn btn-secondary" href="/auth/whoop/start">Reconnect</a>
            <span class="hint-text">Only use this if recovery data stops arriving or you see an error above.</span>
        </p>
    }
    else
    {
        <p>Not connected yet.</p>
        <a class="btn" href="/auth/whoop/start">Connect WHOOP</a>
    }
</section>

<section class="card">
    <h2>Today's recovery</h2>
    @if (!Model.WhoopConnected)
    {
        <p class="subtitle">Connect WHOOP to see your recovery score.</p>
    }
    else if (Model.LatestRecovery is null)
    {
        <p class="subtitle">No recovery data yet. WHOOP scores recoveries within a few hours of waking — refresh this page once you've been awake a while if you're expecting data.</p>
    }
    else if (Model.LatestRecovery.ScoreState == ScoreState.Scored && Model.LatestRecovery.RecoveryScore.HasValue)
    {
        <div class="recovery">
            <div class="recovery-score">@Model.LatestRecovery.RecoveryScore</div>
            <div class="recovery-detail">
                <span class="badge badge-scored">SCORED</span>
                <dl class="metrics">
                    <dt>HRV</dt>
                    <dd>@(Model.LatestRecovery.HrvRmssdMilli?.ToString("F1") ?? "—") ms</dd>
                    <dt>RHR</dt>
                    <dd>@(Model.LatestRecovery.RestingHeartRate?.ToString() ?? "—") bpm</dd>
                </dl>
            </div>
        </div>
    }
    else if (Model.LatestRecovery.ScoreState == ScoreState.PendingScore)
    {
        <p><span class="badge badge-pending">PENDING_SCORE</span> WHOOP is still scoring this cycle. Refresh this page in a few minutes.</p>
    }
    else if (Model.LatestRecovery.ScoreState == ScoreState.Unscorable)
    {
        <p><span class="badge badge-unscorable">UNSCORABLE</span> Recovery unavailable for this cycle.</p>
    }
</section>

@if (Model.DailyCard is not null)
{
    <section class="card daily-card">
        <h2>Today's plan</h2>
        @if (Model.DailyCard.IsStub)
        {
            <p class="banner-warning" role="alert">
                <span class="banner-text">
                    Scaffolding only — this is a placeholder card. The SomaCore&nbsp;AI
                    lands once Tai signs off on persona + bounds + privacy review.
                    See ADR&nbsp;0012.
                </span>
            </p>
        }
        <p class="daily-read">@Model.DailyCard.TodaysRead</p>
        @if (Model.DailyCard.Actions.Count > 0)
        {
            <ol class="daily-actions">
                @foreach (var a in Model.DailyCard.Actions.OrderBy(x => x.Rank))
                {
                    <li>
                        <strong>@a.Title</strong>
                        <details>
                            <summary class="subtitle">Why this · <code>@a.Category</code></summary>
                            <p>@a.Why</p>
                        </details>
                    </li>
                }
            </ol>
        }
        <p class="subtitle daily-provenance">
            Generated @MountainTime.Format(Model.DailyCard.GeneratedAt)
            · model <code>@Model.DailyCard.ModelId</code>
            @if (Model.DailyCard.CostEstimateCents is int cents)
            {
                <text> · est. cost @(cents)¢</text>
            }
        </p>
    </section>
}

@if (Model.QuickLogEnabled)
{
    <section class="card">
        <h2>Tell the coach something</h2>
        <p class="subtitle">
            A meal, a workout, or context it can't see — "lunch: chicken bowl, ~50g protein",
            "45 hard minutes on the bike", "knee's sore, traveling until Friday".
        </p>

        @if (Model.QuickLogBanner is not null)
        {
            <p class="banner-success" role="status"><span class="banner-text">@Model.QuickLogBanner</span></p>
        }
        @if (Model.QuickLogError is not null)
        {
            <p class="banner-warning" role="alert"><span class="banner-text">@Model.QuickLogError</span></p>
        }

        @if (Model.PendingDraft is not null)
        {
            <div class="quicklog-confirm">
                <p><strong>Here's what I understood — confirm before it counts:</strong></p>
                @if (Model.PendingDraft.Meal is { } meal)
                {
                    <p>
                        <span class="badge">MEAL</span>
                        @meal.MealDate.ToString("MMM d") · @meal.MealSlot
                        @if (meal.Calories is { } cal) { <text> · @cal.ToString("0") cal</text> }
                        @if (meal.ProteinG is { } pro) { <text> · @pro.ToString("0")g protein</text> }
                        @if (meal.CarbsG is { } carb) { <text> · @carb.ToString("0")g carbs</text> }
                        @if (meal.FatG is { } fat) { <text> · @fat.ToString("0")g fat</text> }
                        @if (meal.FoodItems.Count > 0)
                        {
                            <text> · @string.Join(", ", meal.FoodItems.Select(i => i.Name))</text>
                        }
                    </p>
                }
                @if (Model.PendingDraft.Workout is { } workout)
                {
                    <p>
                        <span class="badge">WORKOUT</span>
                        @workout.WorkoutType · @(workout.ElapsedSeconds / 60) min
                        · started @MountainTime.Format(workout.StartedAt)
                        @if (workout.Intensity is { } intensity) { <text> · @intensity</text> }
                        @if (workout.AverageHr is { } hr) { <text> · @hr bpm avg</text> }
                    </p>
                }
                @if (Model.PendingDraft.Note is { } note)
                {
                    <p>
                        <span class="badge">NOTE</span>
                        @note.Note
                        @if (note.Category is { } cat) { <text> · <code>@cat</code></text> }
                        @if (note.ActiveUntil is { } until) { <text> · until @until.ToString("MMM d")</text> }
                    </p>
                }
                <div class="quicklog-confirm-actions">
                    <form method="post" asp-page-handler="QuickLogConfirm" class="inline-form">
                        <input type="hidden" name="draftJson" value="@Model.PendingDraftJson" />
                        <button type="submit" class="btn-primary">Confirm</button>
                    </form>
                    <form method="post" asp-page-handler="QuickLogEdit" class="inline-form">
                        <input type="hidden" name="sourceText" value="@Model.PendingSourceText" />
                        <button type="submit" class="btn-secondary">Edit</button>
                    </form>
                    <a href="/me" class="btn-secondary">Discard</a>
                </div>
            </div>
        }
        else
        {
            <form method="post" asp-page-handler="QuickLog" class="quicklog-form">
                <input type="text" name="quickLogText" value="@Model.QuickLogText"
                       maxlength="@Model.QuickLogMaxChars" required
                       placeholder="What should the coach know?" />
                <button type="submit" class="btn-primary">Log it</button>
            </form>
            <p class="subtitle">
                What you type here is processed by our AI provider — same rules as your
                card data: never used for training, no identifiers attached.
            </p>
        }

        @if (Model.LoggedItems.Count > 0)
        {
            <h3>Logged by you</h3>
            <ul class="quicklog-items">
                @foreach (var item in Model.LoggedItems)
                {
                    <li>
                        <span class="badge">@item.ItemType.ToUpperInvariant()</span>
                        @item.Summary
                        <form method="post" asp-page-handler="QuickLogDelete" class="inline-form">
                            <input type="hidden" name="itemType" value="@item.ItemType" />
                            <input type="hidden" name="itemId" value="@item.Id" />
                            <button type="submit" class="btn-link" aria-label="Delete this entry">delete</button>
                        </form>
                    </li>
                }
            </ul>
        }
    </section>
}

@if (Model.RecentRecoveries.Count > 0)
{
    <section class="card">
        <h2>Recent recoveries</h2>
        <p class="subtitle">Last @Model.RecentRecoveries.Count, newest first. Times shown in Mountain.</p>
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Cycle start</th>
                        <th>Score</th>
                        <th>State</th>
                        <th>HRV (ms)</th>
                        <th>RHR (bpm)</th>
                        <th>Sleep</th>
                        <th>Source</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.RecentRecoveries)
                    {
                        <tr>
                            <td>@MountainTime.Format(r.CycleStartAt)</td>
                            <td>@(r.RecoveryScore?.ToString() ?? "—")</td>
                            <td><span class="badge @BadgeClass(r.ScoreState)">@r.ScoreState</span></td>
                            <td>@(r.HrvRmssdMilli?.ToString("F1") ?? "—")</td>
                            <td>@(r.RestingHeartRate?.ToString() ?? "—")</td>
                            <td>
                                @if (r.SleepStartAt.HasValue && r.SleepEndAt.HasValue)
                                {
                                    @MountainTime.FormatTimeShort(r.SleepStartAt.Value) <text> → </text> @MountainTime.FormatTimeShort(r.SleepEndAt.Value)
                                }
                                else
                                {
                                    <span class="subtitle">—</span>
                                }
                            </td>
                            <td><code>@r.IngestedVia</code></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@if (Model.WhoopConnected)
{
    <form method="post" action="/auth/whoop/disconnect" class="disconnect-form">
        <button type="submit" class="btn-link-danger">Disconnect WHOOP</button>
    </form>
}

@if (Model.LatestRecovery is not null)
{
    <details>
        <summary>Latest recovery provenance</summary>
        <dl>
            <dt>Cycle window</dt>
            <dd>
                @MountainTime.Format(Model.LatestRecovery.CycleStartAt)
                – @(Model.LatestRecovery.CycleEndAt.HasValue ? MountainTime.Format(Model.LatestRecovery.CycleEndAt.Value) : "(in progress)")
            </dd>
            <dt>Ingested via</dt>
            <dd><code>@Model.LatestRecovery.IngestedVia</code></dd>
            <dt>Ingested at</dt>
            <dd>@MountainTime.Format(Model.LatestRecovery.IngestedAt)</dd>
        </dl>
    </details>
}

<details>
    <summary>Diagnostics</summary>
    <dl>
        <dt>Entra OID</dt>
        <dd><code>@Model.EntraOid</code></dd>
        <dt>SomaCore user ID</dt>
        <dd><code>@Model.SomaCoreUserId</code></dd>
        <dt>Last seen</dt>
        <dd>@MountainTime.Format(Model.LastSeenAt)</dd>
    </dl>
</details>

@if (Model.IsAdmin)
{
    <p class="signout"><a href="/admin/users">Admin: users</a> · <a href="/admin/health">Admin: health</a> · <a href="/admin/backfill">Admin: backfill</a> · <a href="/admin/agent">Admin: agent</a></p>
}

<p class="signout"><a href="/MicrosoftIdentity/Account/SignOut">Sign out</a></p>

@functions {
    static string BadgeClass(string state) => state switch
    {
        "SCORED"        => "badge-scored",
        "PENDING_SCORE" => "badge-pending",
        "UNSCORABLE"    => "badge-unscorable",
        _               => "badge-unscorable",
    };
}
